{
  "buildCommand": "cd apps/frontend && npm ci --legacy-peer-deps && npm run build",
  "outputDirectory": "apps/frontend/dist/frontend/browser",
  "rewrites": [
    {
      "source": "/actuator/:path*",
      "destination": "https://industrial-hub.onrender.com/actuator/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://industrial-hub.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
