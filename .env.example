# ─────────────────────────────────────────────────────────────────
# Variáveis de ambiente — Vercel + Render + Supabase
# Configure cada variável no painel da plataforma correspondente.
# NUNCA comite um arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────

# ── Banco de dados (Supabase → Project Settings → Database) ──────
# Host: db.<seu-projeto>.supabase.co
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# ── Backend (Render → Environment Variables) ──────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=

# URL pública do frontend no Vercel (sem barra no final)
CORS_ALLOWED_ORIGINS=https://seu-projeto.vercel.app

# ── Frontend (vercel.json rewrites — substituir pelo URL real do Render) ──────
# URL pública do backend no Render (sem barra no final)
BACKEND_URL=https://industrial-hub-backend.onrender.com

# ── Storage S3-compatible (Cloudflare R2 — 10 GB grátis) ─────────
# Criar bucket em: dash.cloudflare.com → R2 → Create bucket
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_BUCKET=industrial-hub
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto

# ── Email (opcional — Gmail SMTP com App Password) ────────────────
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@msb.com.br
